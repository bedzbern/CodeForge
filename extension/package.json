{
  "name": "codeforge-student",
  "displayName": "CodeForge Student",
  "description": "Student-facing AI coding assistant for school computer labs",
  "version": "0.1.0",
  "publisher": "codeforge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeforge-sidebar",
          "title": "CodeForge",
          "icon": "$(question)"
        }
      ]
    },
    "views": {
      "codeforge-sidebar": [
        {
          "type": "webview",
          "id": "codeforge.askPanel",
          "name": "Ask CodeForge"
        }
      ]
    },
    "commands": [
      {
        "command": "codeforge.ask",
        "title": "Open CodeForge Panel",
        "category": "CodeForge"
      }
    ],
    "configuration": {
      "title": "CodeForge",
      "properties": {
        "codeforge.serverUrl": {
          "type": "string",
          "default": "http://192.168.1.1:8000",
          "description": "URL of the CodeForge server"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  }
}
