# CodeForge Environment Variables

# AI Provider: "groq" or "ollama"
AI_PROVIDER=groq

# Groq API key (required if AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# Ollama base URL (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Teacher PC IP (used for API auth and Socket.IO auth)
TEACHER_IP=192.168.1.1
